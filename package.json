{
  "name": "leanme-event",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:partners": "node scripts/sync-partner-logos.mjs",
    "trim:agents": "node scripts/trim-agent-hp-images.mjs",
    "enhance:agents": "node scripts/enhance-agent-hp-images.mjs",
    "logo:transparent": "node scripts/logo-transparent-png.mjs",
    "copy:ffmpeg": "node scripts/copy-ffmpeg-core.mjs",
    "lean-event:access": "node scripts/generate-lean-event-access.mjs",
    "lean-event:vercel-env": "node scripts/print-lean-event-vercel-env.mjs",
    "lean-event:sync-vercel": "node scripts/sync-lean-event-vercel-env.mjs",
    "lean-event:import-templates": "node scripts/generate-lean-event-import-templates.mjs",
    "lean-event:migrate-neon-dry": "node scripts/migrate-lean-event-neon-dry.mjs",
    "lean-event:migrate-neon": "node --env-file=.env.local scripts/migrate-lean-event-neon.mjs",
    "lean-event:verify-neon": "node --env-file=.env.local scripts/verify-neon-schema.mjs",
    "lean-event:apply-neon-001": "node --env-file=.env.local scripts/apply-neon-001.mjs",
    "lean-event:apply-neon-002": "node --env-file=.env.local scripts/apply-neon-002.mjs",
    "lean-event:apply-neon-003": "node --env-file=.env.local scripts/apply-neon-003.mjs",
    "lean-event:compare-neon-blob": "node --env-file=.env.local scripts/compare-neon-blob.mjs",
    "lean-event:list-neon": "node --env-file=.env.local scripts/list-neon-entities.mjs",
    "prebuild": "npm run sync:partners && npm run copy:ffmpeg && npm run lean-event:import-templates",
    "dev": "node scripts/run-dev.mjs",
    "build": "node scripts/run-build.mjs",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.6",
    "@ffmpeg/ffmpeg": "0.12.10",
    "@ffmpeg/util": "^0.12.2",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.23.12",
    "geist": "^1.5.1",
    "jose": "^6.2.3",
    "next": "^15.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2"
  }
}
