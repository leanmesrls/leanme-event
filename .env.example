# Lean.Event — environment variables (copy to .env.local)

NEXT_PUBLIC_SITE_URL=https://events.leanme.it

# --- Core auth (fail-closed: no legacy secret fallbacks in runtime) ---
LEAN_EVENT_SESSION_SECRET=change-me-to-a-long-random-string

# --- Control Plane (required for architecture v1.0) ---
LEAN_EVENT_CONTROL_PLANE_DATABASE_URL=

# --- Product / build identity ---
LEAN_EVENT_PRODUCT_VERSION=0.1.0
LEAN_EVENT_ARCHITECTURE_VERSION=1.0.0
# LEAN_EVENT_RELEASE_NAME=
# LEAN_EVENT_BUILD_NUMBER=
# LEAN_EVENT_GIT_COMMIT=
# LEAN_EVENT_BUILD_TIME=
# LEAN_EVENT_ENVIRONMENT=development

# --- Inngest (official async job engine) ---
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- AI provider (accessed only via AI Gateway) ---
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_STRUCTURING_MODEL=gpt-4.1-mini

# --- Per-tenant secret refs (examples) ---
# Tenant Registry stores references like:
#   databaseRef = LEAN_EVENT_TENANT_IEC_DATABASE_URL
# Document binaries live in the tenant Postgres DB (schema 008).
# Blob tokens below are cutover-only (legacy read / inventory) — not runtime SoT.
# LEAN_EVENT_TENANT_IEC_DATABASE_URL=
# LEAN_EVENT_TENANT_IEC_BLOB_TOKEN=
# LEAN_EVENT_TENANT_DEMO_DATABASE_URL=
# LEAN_EVENT_TENANT_DEMO_BLOB_TOKEN=

# --- Neon API (optional, for automated DB provisioning) ---
# NEON_API_KEY=
# NEON_PROJECT_ID=

# --- Vercel API (optional ops; do not provision Blob as SoT) ---
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# --- Local / cutover helpers ---
# LEAN_EVENT_DATABASE_URL=
# BLOB_READ_WRITE_TOKEN=
# LEAN_EVENT_LEGACY_BLOB_TOKEN=   # RW token of store leanme-event (dashboard)
# LEAN_EVENT_BLOB_LEGACY_READ=1   # set 0 to disable Blob read fallback
# LEAN_EVENT_R03_STRICT=0         # set 1 to also forbid @vercel/blob in scripts/
# LEAN_EVENT_DATA_DIR=.lean-event-data
# LEAN_EVENT_TENANTS_FILE=.lean-event-data/tenants.json

# Platform admin emails (CSV)
# LEAN_EVENT_PLATFORM_ADMIN_EMAILS=luana.martuzzi@leanme.it,info@leanme.it
