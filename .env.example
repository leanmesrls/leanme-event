# LeanMe site — environment variables (copy to .env.local)

NEXT_PUBLIC_SITE_URL=https://events.leanme.it

# Lean Event (area riservata clienti)
LEAN_EVENT_SESSION_SECRET=change-me-to-a-long-random-string
LEAN_EVENT_DATA_DIR=.lean-event-data
LEAN_EVENT_TENANTS_FILE=.lean-event-data/tenants.json
# Produzione Vercel: sync automatico con npm run lean-event:sync-vercel (dopo vercel link)
# Fallback manuale: npm run lean-event:vercel-env → incolla in Vercel → LEAN_EVENT_TENANTS_JSON
# LEAN_EVENT_TENANTS_JSON={"tenants":[...]}

# OpenAI — required for Leonardo Secretary Assistant processing
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_STRUCTURING_MODEL=gpt-4.1-mini

# Vercel Blob — workspace Lean Event persistenti in produzione (auto se colleghi Blob Store)
# BLOB_READ_WRITE_TOKEN=

# Neon Postgres — schema tipizzato + FK: docs/sql/006_lean_event_normalized.sql
# LEAN_EVENT_DATABASE_URL=
# DATABASE_URL=
# LEAN_EVENT_DB_STRICT=1   # default: se URL presente, errori Neon falliscono le mutazioni; 0 = solo log
# LEAN_EVENT_READ_FROM_NEON=1   # cutover Fase B: letture da lean_event_entities JSONB
# Cutover normalizzato (docs/lean-event-normalized-cutover.md):
# LEAN_EVENT_NORMALIZED_SOT=1       # write su tabelle tipizzate
# LEAN_EVENT_READ_NORMALIZED=1      # read da tabelle tipizzate (N3)
# LEAN_EVENT_LEGACY_ENTITY_MIRROR=1 # mirror su lean_event_entities (default se NORMALIZED_SOT)
# Apply/migrate: npm run lean-event:apply-neon-006 && npm run lean-event:migrate-normalized
# Verify: npm run lean-event:verify-normalized

# Operatori piattaforma LeanMe (supervisione Teresa globale). CSV email.
# Se assente: qualsiasi sessione con email @leanme.it.
# LEAN_EVENT_PLATFORM_ADMIN_EMAILS=luana.martuzzi@leanme.it,info@leanme.it
# Migrazione locale → Neon: npm run lean-event:migrate-neon
# Verifica schema: npm run lean-event:verify-neon
